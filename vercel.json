{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/web-mundial/browser",
  "framework": "angular",
  "functions": {
    "api/**/*.js": {
      "runtime": "vercel-node@20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}